{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "rut-ai@kia.prz.edu.pl",
    "ExpireMinutes": 10
  },
  "RefreshToken": {
    "ExpireDays": 1,
    "ExpireDaysRememberMe": 10
  },
  "MailSettings": {
    "Host": "smtp.kia.prz.edu.pl",
    "DefaultCredentials": false,
    "Port": 587,
    "Name": "RUT-AI Games",
    "EmailId": "rut-ai@kia.prz.edu.pl",
    "UserName": "rut-ai",
    "UseSSL": false
  },
  "Rag2Ai": {
    "Enabled": true,
    "BaseUrl": "http://localhost:8888",
    "RoutesPath": "/",
    "CacheMinutes": 10,
    "FallbackOfficialModels": [
      "PPO", "ARS", "TRPO", "BOT", "DQN",
      "flappybird-ppo", "flappybird-ars", "flappybird-trpo",
      "crossyroad-ppo", "crossyroad-dqn", "crossyroad-trpo"
    ]
  },
  "Redis": {
    "Stats": {
      "Prefix": "GameStats:",
      "OverallStatsKey": "overall"
    },
    "Leaderboard": {
      "Prefix": "Leaderboard:",
      "TtlDays": 1
    },
    "Rag2Ai": {
      "Prefix": "Rag2Ai:"
    }
  }
